{
  "description": "Contract tests for getOccurrencesBetween — shared between Flutter (Dart) and web (TypeScript)",
  "conventions": {
    "daysOfWeek": "ISO 8601: 1=Monday, 7=Sunday. TypeScript tests must convert to JS convention (0=Sun, 6=Sat).",
    "dates": "ISO 8601 strings YYYY-MM-DD, interpreted as UTC midnight.",
    "includeAnchor": "Always specified explicitly. Dart defaults true, TS defaults false — never rely on defaults."
  },
  "cases": [
    {
      "id": "daily_interval_1",
      "description": "Simple daily recurrence, every day for 5 days",
      "pattern": {
        "type": "daily",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-06",
      "endDate": "2025-01-10",
      "anchorDate": "2025-01-06",
      "includeAnchor": true,
      "expected": ["2025-01-06", "2025-01-07", "2025-01-08", "2025-01-09", "2025-01-10"]
    },
    {
      "id": "daily_interval_3",
      "description": "Every 3 days",
      "pattern": {
        "type": "daily",
        "interval": 3,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-01",
      "endDate": "2025-01-15",
      "anchorDate": "2025-01-01",
      "includeAnchor": true,
      "expected": ["2025-01-01", "2025-01-04", "2025-01-07", "2025-01-10", "2025-01-13"]
    },
    {
      "id": "daily_max_occurrences",
      "description": "Daily with maxOccurrences=3",
      "pattern": {
        "type": "daily",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": 3
      },
      "startDate": "2025-01-01",
      "endDate": "2025-01-31",
      "anchorDate": "2025-01-01",
      "includeAnchor": true,
      "expected": ["2025-01-01", "2025-01-02", "2025-01-03"]
    },
    {
      "id": "daily_exclude_anchor",
      "description": "Daily excluding anchor date",
      "pattern": {
        "type": "daily",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-06",
      "endDate": "2025-01-09",
      "anchorDate": "2025-01-06",
      "includeAnchor": false,
      "expected": ["2025-01-07", "2025-01-08", "2025-01-09"]
    },
    {
      "id": "daily_with_end_date",
      "description": "Daily with pattern endDate before range endDate",
      "pattern": {
        "type": "daily",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": "2025-01-08",
        "maxOccurrences": null
      },
      "startDate": "2025-01-06",
      "endDate": "2025-01-15",
      "anchorDate": "2025-01-06",
      "includeAnchor": true,
      "expected": ["2025-01-06", "2025-01-07", "2025-01-08"]
    },
    {
      "id": "weekly_single_day",
      "description": "Weekly every Monday (ISO day 1)",
      "pattern": {
        "type": "weekly",
        "interval": 1,
        "daysOfWeek": [1],
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-06",
      "endDate": "2025-01-27",
      "anchorDate": "2025-01-06",
      "includeAnchor": true,
      "expected": ["2025-01-06", "2025-01-13", "2025-01-20", "2025-01-27"]
    },
    {
      "id": "weekly_multiple_days",
      "description": "Weekly on Monday (1) and Wednesday (3)",
      "pattern": {
        "type": "weekly",
        "interval": 1,
        "daysOfWeek": [1, 3],
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-06",
      "endDate": "2025-01-22",
      "anchorDate": "2025-01-06",
      "includeAnchor": true,
      "expected": ["2025-01-06", "2025-01-08", "2025-01-13", "2025-01-15", "2025-01-20", "2025-01-22"]
    },
    {
      "id": "weekly_interval_2",
      "description": "Every 2 weeks on Monday (1) and Wednesday (3) — tests interval skipping",
      "pattern": {
        "type": "weekly",
        "interval": 2,
        "daysOfWeek": [1, 3],
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-06",
      "endDate": "2025-02-02",
      "anchorDate": "2025-01-06",
      "includeAnchor": true,
      "expected": ["2025-01-06", "2025-01-08", "2025-01-20", "2025-01-22"]
    },
    {
      "id": "weekly_anchor_not_on_target_day",
      "description": "Anchor on Thursday (4), recurring on Monday (1) and Wednesday (3) — seriesStart should shift forward",
      "pattern": {
        "type": "weekly",
        "interval": 1,
        "daysOfWeek": [1, 3],
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-09",
      "endDate": "2025-01-22",
      "anchorDate": "2025-01-09",
      "includeAnchor": true,
      "expected": ["2025-01-13", "2025-01-15", "2025-01-20", "2025-01-22"]
    },
    {
      "id": "weekly_interval_2_anchor_not_on_target",
      "description": "Every 2 weeks on Monday (1), anchor on Wednesday — interval counted from first valid week",
      "pattern": {
        "type": "weekly",
        "interval": 2,
        "daysOfWeek": [1],
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-08",
      "endDate": "2025-02-10",
      "anchorDate": "2025-01-08",
      "includeAnchor": true,
      "expected": ["2025-01-13", "2025-01-27", "2025-02-10"]
    },
    {
      "id": "weekly_no_days_specified",
      "description": "Weekly with no daysOfWeek — uses anchor's weekday (Monday)",
      "pattern": {
        "type": "weekly",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-06",
      "endDate": "2025-01-27",
      "anchorDate": "2025-01-06",
      "includeAnchor": true,
      "expected": ["2025-01-06", "2025-01-13", "2025-01-20", "2025-01-27"]
    },
    {
      "id": "monthly_day_15",
      "description": "Monthly on the 15th",
      "pattern": {
        "type": "monthly",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": 15,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-15",
      "endDate": "2025-04-15",
      "anchorDate": "2025-01-15",
      "includeAnchor": true,
      "expected": ["2025-01-15", "2025-02-15", "2025-03-15", "2025-04-15"]
    },
    {
      "id": "monthly_day_31_clamp",
      "description": "Monthly on day 31 — clamps to last day of shorter months",
      "pattern": {
        "type": "monthly",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": 31,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-31",
      "endDate": "2025-05-31",
      "anchorDate": "2025-01-31",
      "includeAnchor": true,
      "expected": ["2025-01-31", "2025-02-28", "2025-03-31", "2025-04-30", "2025-05-31"]
    },
    {
      "id": "monthly_interval_2",
      "description": "Every 2 months on day 10",
      "pattern": {
        "type": "monthly",
        "interval": 2,
        "daysOfWeek": null,
        "dayOfMonth": 10,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-01-10",
      "endDate": "2025-07-10",
      "anchorDate": "2025-01-10",
      "includeAnchor": true,
      "expected": ["2025-01-10", "2025-03-10", "2025-05-10", "2025-07-10"]
    },
    {
      "id": "yearly_basic",
      "description": "Yearly on March 15",
      "pattern": {
        "type": "yearly",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2025-03-15",
      "endDate": "2028-03-15",
      "anchorDate": "2025-03-15",
      "includeAnchor": true,
      "expected": ["2025-03-15", "2026-03-15", "2027-03-15", "2028-03-15"]
    },
    {
      "id": "yearly_feb29_leap_to_non_leap",
      "description": "Yearly starting Feb 29 in leap year — clamps to Feb 28 in non-leap years",
      "pattern": {
        "type": "yearly",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2024-02-29",
      "endDate": "2028-03-01",
      "anchorDate": "2024-02-29",
      "includeAnchor": true,
      "expected": ["2024-02-29", "2025-02-28", "2026-02-28", "2027-02-28", "2028-02-29"]
    },
    {
      "id": "yearly_feb29_exclude_anchor",
      "description": "Yearly Feb 29 excluding anchor",
      "pattern": {
        "type": "yearly",
        "interval": 1,
        "daysOfWeek": null,
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": null
      },
      "startDate": "2024-02-29",
      "endDate": "2027-03-01",
      "anchorDate": "2024-02-29",
      "includeAnchor": false,
      "expected": ["2025-02-28", "2026-02-28", "2027-02-28"]
    },
    {
      "id": "weekly_max_occurrences",
      "description": "Weekly Mon/Wed with maxOccurrences=4",
      "pattern": {
        "type": "weekly",
        "interval": 1,
        "daysOfWeek": [1, 3],
        "dayOfMonth": null,
        "endDate": null,
        "maxOccurrences": 4
      },
      "startDate": "2025-01-06",
      "endDate": "2025-02-28",
      "anchorDate": "2025-01-06",
      "includeAnchor": true,
      "expected": ["2025-01-06", "2025-01-08", "2025-01-13", "2025-01-15"]
    }
  ]
}
