{
  "description": "Contract tests for role hierarchy and permission predicates — shared between Flutter (Dart) and web (TypeScript)",
  "conventions": {
    "roles": "Valid roles: 'superadmin', 'admin', 'user', 'volunteer'. Null/empty treated as unprivileged.",
    "predicates": "Each predicate returns a boolean. Predicates: 'isSuperAdmin', 'isAtLeastAdmin', 'isVolunteer'."
  },
  "cases": [
    {
      "id": "superadmin_is_superadmin",
      "role": "superadmin",
      "expected": { "isSuperAdmin": true, "isAtLeastAdmin": true, "isVolunteer": false }
    },
    {
      "id": "admin_is_not_superadmin",
      "role": "admin",
      "expected": { "isSuperAdmin": false, "isAtLeastAdmin": true, "isVolunteer": false }
    },
    {
      "id": "user_has_no_elevated_perms",
      "role": "user",
      "expected": { "isSuperAdmin": false, "isAtLeastAdmin": false, "isVolunteer": false }
    },
    {
      "id": "volunteer_is_volunteer",
      "role": "volunteer",
      "expected": { "isSuperAdmin": false, "isAtLeastAdmin": false, "isVolunteer": true }
    },
    {
      "id": "null_role",
      "description": "Null role treated as unprivileged",
      "role": null,
      "expected": { "isSuperAdmin": false, "isAtLeastAdmin": false, "isVolunteer": false }
    },
    {
      "id": "empty_string_role",
      "description": "Empty string treated as unprivileged",
      "role": "",
      "expected": { "isSuperAdmin": false, "isAtLeastAdmin": false, "isVolunteer": false }
    }
  ]
}
